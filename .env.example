# Copiar a .env.base y .env.local según local.sh
# Las variables se cargan con: source .env.base && source .env.local

# DB Identity
IDENTITY_DB_HOST=identitydb
IDENTITY_DB_PORT=5432
IDENTITY_DB_NAME=identity
IDENTITY_DB_USER=identity
IDENTITY_DB_PASS=secret

# DB Catalog
CATALOG_DB_HOST=catalogdb
CATALOG_DB_PORT=5432
CATALOG_DB_NAME=catalog
CATALOG_DB_USER=catalog
CATALOG_DB_PASS=secret

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# MinIO
MINIO_USER=minioadmin
MINIO_PASS=minioadmin
MINIO_BUCKET_IMAGES=images
MINIO_BUCKET_MODELS=models
MINIO_PUBLIC_ENDPOINT=http://localhost:8000

# Puertos
IDENTITY_PORT=8081
CATALOG_PORT=8082
DOCUMENT_PORT=8083
MUMA_PORT=8084

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT (secret compartido: identity firma, catalog/document validan)
# Mínimo 32 caracteres recomendado. Mismo valor en todos los servicios.
JWT_SECRET=muma-jwt-secret-key-at-least-32-chars-long

# Test
TEST_VARS=true
